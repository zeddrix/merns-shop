{
  "name": "merns-shop",
  "version": "1.0.0",
  "description": "Mern's Shop — MERN e-commerce app",
  "main": "backend/server.ts",
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "postinstall": "node scripts/validate-catalog-images.mjs || node scripts/fetch-catalog-images.mjs --fetch --webp",
    "images:ensure": "node scripts/ensure-product-images.mjs && node scripts/validate-catalog-images.mjs",
    "catalog:manifest": "tsx scripts/generate-catalog-manifest.ts",
    "catalog:sources": "node scripts/resolve-catalog-image-sources.mjs",
    "catalog:sources:official": "node scripts/resolve-official-catalog-sources.mjs",
    "catalog:harvest:official": "node scripts/harvest-official-catalog-sources.mjs",
    "catalog:harvest:wave4": "node scripts/sync-wave4-official-sources.mjs && node scripts/fill-wave4-official-donors.mjs",
    "catalog:repair:official": "node scripts/repair-official-catalog-sources.mjs",
    "catalog:validate:official": "node scripts/validate-official-catalog-sources.mjs",
    "catalog:harvest:checklist": "node scripts/print-official-harvest-checklist.mjs",
    "catalog:sources:fallbacks": "node scripts/assign-catalog-fallback-sources.mjs",
    "catalog:images": "node scripts/fetch-catalog-images.mjs --fetch --webp --force",
    "catalog:audit": "node scripts/audit-catalog-image-relevance.mjs",
    "catalog:fix:audit": "node scripts/fix-audit-failures.mjs",
    "catalog:apply:curated": "node scripts/apply-curated-catalog-sources.mjs",
    "catalog:curate:search": "node scripts/search-curate-catalog-images.mjs",
    "catalog:apply:web-curated": "node scripts/apply-web-curated-catalog-sources.mjs",
    "catalog:patch:broken-urls": "node scripts/patch-broken-catalog-urls.mjs",
    "catalog:hand-curate": "node scripts/hand-curate-catalog-heroes.mjs",
    "catalog:apply:agent-fixes": "node scripts/apply-agent-visual-fixes.mjs",
    "catalog:visual-review": "node scripts/build-catalog-visual-review.mjs",
    "catalog:validate": "node scripts/validate-catalog-prices.mjs && node scripts/validate-catalog-images.mjs",
    "start": "node dist/backend/server.js",
    "server": "tsx watch backend/server.ts",
    "client": "pnpm --filter merns-shop-frontend dev",
    "dev": "bash scripts/run-with-project-node.sh run dev:inner",
    "dev:inner": "concurrently -n api,vite -c blue,green \"PORT=5021 pnpm exec tsx watch backend/server.ts\" \"pnpm client\"",
    "build": "pnpm --filter merns-shop-frontend build && pnpm build:backend",
    "build:backend": "tsc -p backend/tsconfig.build.json",
    "db:seed": "tsx backend/seeder.ts -i",
    "db:destroy": "tsx backend/seeder.ts -d",
    "db:ping:atlas": "tsx scripts/db-ping-atlas.ts",
    "db:seed:prod": "NODE_ENV=production tsx backend/seeder.ts -i",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0 --cache --cache-location node_modules/.cache/eslint",
    "lint:fix": "eslint . --cache --cache-location node_modules/.cache/eslint --fix",
    "check": "concurrently -n backend,frontend,tests \"pnpm check:backend\" \"pnpm check:frontend\" \"pnpm check:tests\"",
    "check:backend": "tsc --noEmit -p backend/tsconfig.json",
    "check:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "check:tests": "tsc --noEmit -p tests/tsconfig.json",
    "quality:types-and-lint": "concurrently -n check,lint -c blue,green \"pnpm check\" \"pnpm lint\"",
    "quality": "pnpm format && pnpm quality:types-and-lint",
    "quality:fast": "pnpm quality:types-and-lint",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:integration:one": "vitest run",
    "test:e2e": "PW_DISABLE_REUSE_SERVER=1 playwright test",
    "test:e2e:one": "PW_DISABLE_REUSE_SERVER=1 playwright test --workers=1",
    "test:e2e:dev": "playwright test",
    "test:e2e:catalog": "PW_WORKERS=1 playwright test tests/e2e/catalog",
    "test:e2e:auth": "PW_WORKERS=1 playwright test tests/e2e/auth",
    "test:e2e:checkout": "PW_WORKERS=1 playwright test tests/e2e/checkout",
    "test:e2e:admin": "PW_WORKERS=1 playwright test tests/e2e/admin",
    "test:e2e:misc": "PW_WORKERS=1 playwright test tests/e2e/misc",
    "test:e2e:paypal": "PW_WORKERS=1 playwright test tests/e2e/checkout/paypal-sandbox-payment.e2e.test.ts",
    "test:e2e:journeys": "PW_WORKERS=1 playwright test tests/e2e/journeys",
    "test:e2e:ui": "playwright test --ui",
    "verify": "pnpm format:check && pnpm quality:fast && pnpm test:unit && pnpm test:integration && pnpm build",
    "verify:full": "bash scripts/pre-deploy-verify.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zeddrix/merns-shop"
  },
  "author": "Zeddrix Fabian",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-async-handler": "^1.2.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^9.0.0",
    "morgan": "^1.10.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "happy-dom": "^20.10.1",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.9"
  }
}
