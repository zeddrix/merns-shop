{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@types/*": ["../types/*"]
    }
  },
  "include": [
    "./unit/**/*.ts",
    "./integration/**/*.ts",
    "./vitest-setup.ts",
    "../types/**/*.ts",
    "../backend/types/**/*.d.ts",
    "../frontend/src/vite-env.d.ts",
    "../scripts/is-polluted-official-url.mjs",
    "../scripts/official-category-donors.mjs",
    "../scripts/catalog-image-relevance.mjs"
  ],
  "exclude": ["./e2e/**", "node_modules"]
}
