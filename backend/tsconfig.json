{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../dist",
    "rootDir": "..",
    "resolveJsonModule": true,
    "noEmit": true,
    "composite": true
  },
  "include": ["**/*.ts", "types/**/*.d.ts", "../shared/**/*.ts"],
  "exclude": ["node_modules"]
}
