# Local development — copy to `.env`
PORT=5021
MONGO_URI=mongodb://127.0.0.1:27017/merns-shop
JWT_SECRET=change-me-to-a-long-random-secret
NODE_ENV=development
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
# Public site URL for SEO (canonical, Open Graph). Frontend dev server origin.
VITE_SITE_URL=http://localhost:5020
# Backend public URL (sitemap, robots, bot HTML). Same host as API in production.
SITE_URL=http://localhost:5021
